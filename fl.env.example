# fl.env.example - copy to `fl.env` and edit for THIS server.
# Sourced by run_fl.sh. Keep `fl.env` out of git (it holds deployment paths and,
# optionally, the API key). All values override the defaults in config.py.

# --- model provider (DeepSeek) ---
# Either set the key here, or put it alone in deepseek_key.txt next to run_fl.sh.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# If the server reaches DeepSeek only through a proxy:
# HTTPS_PROXY=http://proxy.internal:8080

# --- target system code artifacts (deployed jars, built index) ---
OH_FL_JARS=/opt/yudao                                  # dir of deployed *-server.jar
OH_FL_INDEX=/opt/microservicefl/endpoint_index.json    # built by: fl build-index
OH_FL_CFR=/root/tools/cfr-0.152.jar                    # CFR (installed by install-fl.sh)

# --- data source: live SkyWalking (recommended) ---
OH_FL_DATASOURCE=skywalking
OH_FL_SKYWALKING_URL=http://127.0.0.1:12800/graphql    # your OAP GraphQL endpoint
OH_FL_METRIC_CSV=/var/lib/collector/metric.csv         # live psutil CSV (cpu/mem)
OH_FL_LOG_CSV=/var/lib/collector/log.csv               # live log CSV (error logs)

# --- OR offline data source (analyse an ingested snapshot) ---
# OH_FL_DATASOURCE=duckdb
# OH_FL_DB=/opt/microservicefl/fl.duckdb

# --- target-system naming profile (default: yudao-cloud) ---
# OH_FL_TARGET=yudao-cloud
